+
+function getTuningSummary() {
+  const rate = document.querySelector('#rate')?.value || '+0%';
+  const pitch = document.querySelector('#pitch')?.value || '+0Hz';
+  const volume = document.querySelector('#volume')?.value || '+0%';
+  const changes = [];
